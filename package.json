{
  "name": "@wlearn/nn",
  "version": "0.1.0",
  "description": "Neural tabular models (MLP, TabM, NAM) for wlearn via polygrad",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "node test/test.js && node test/test_nam.js && node test/test_tabm.js && node test/test_cross_lang.js"
  },
  "dependencies": {
    "@wlearn/core": "0.1.0"
  },
  "peerDependencies": {
    "polygrad": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "polygrad": {
      "optional": false
    }
  },
  "keywords": [
    "neural-network", "mlp", "machine-learning", "wlearn", "polygrad"
  ],
  "author": "Anton Zemlyansky",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/nn.git"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
